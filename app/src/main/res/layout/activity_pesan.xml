<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF4EC"
    tools:context=".PesanActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtJudul"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pesan"
                    android:textColor="#2F2F2F"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="18dp"
                    android:src="@drawable/uil_search"
                    android:tint="#333333"/>

                <ImageView
                    android:id="@+id/btnTambah"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:tint="#FF6B8A"/>

            </LinearLayout>

            <!-- SPASI -->

            <Space
                android:layout_width="match_parent"
                android:layout_height="18dp"/>

            <!-- CARD CHAT DENGAN LUNA -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/mdi_robot_love"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chat Dengan Luna"
                            android:textStyle="bold"
                            android:textColor="#222222"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanya apa saja tentang siklus dan kesehatanmu."
                            android:textSize="13sp"
                            android:textColor="#666666"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ========================= -->
            <!-- CARD LUNA -->
            <!-- ========================= -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header Luna -->

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/imgLuna"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/mdi_robot_love"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/imgLuna"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Luna"
                                    android:textStyle="bold"
                                    android:textSize="20sp"
                                    android:textColor="#222222"/>

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="5dp"
                                    android:src="@drawable/vector"/>

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hai pika! Ada yang mau kamu tanyakan hari ini ❤️"
                                android:textColor="#555555"
                                android:textSize="13sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="18dp"
                            android:background="@drawable/bg_red_dot"/>

                    </RelativeLayout>

                    <!-- Spasi -->

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="18dp"/>

                    <!-- Tombol 1 -->

                    <Button
                        android:id="@+id/btnHamil"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_question"
                        android:text="Apakah saya hamil?"
                        android:textAllCaps="false"
                        android:textColor="#333333"
                        android:textSize="15sp"/>

                    <!-- Tombol 2 -->

                    <Button
                        android:id="@+id/btnTelat"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_question"
                        android:text="Kenapa telat haid?"
                        android:textAllCaps="false"
                        android:textColor="#333333"
                        android:textSize="15sp"/>

                    <!-- Tombol 3 -->

                    <Button
                        android:id="@+id/btnSubur"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_question"
                        android:text="Kapan masa subur saya?"
                        android:textAllCaps="false"
                        android:textColor="#333333"
                        android:textSize="15sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===================================== -->
            <!-- NOTIFIKASI & INSIGHT -->
            <!-- ===================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifikasi &amp; Insight"
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="20sp"
                android:layout_marginBottom="14dp"/>

            <!-- CARD FASE LUTEAL -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="10dp"
                        android:src="@drawable/mingcute_loading_3_fill"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fase Luteal"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:textColor="#222222"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kamu sedang berada di fase luteal.\nJaga kesehatan dan istirahat yang cukup ya!"
                            android:textSize="13sp"
                            android:textColor="#666666"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19.50"
                        android:textSize="11sp"
                        android:textColor="#999999"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CARD MINUM AIR -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="10dp"
                        android:src="@drawable/streamline_sharp_color_water_drop_1_flat"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ingat Minum Air"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:textColor="#222222"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Minum air yang cukup membantu tubuh tetap sehat dan bertenaga."
                            android:textSize="13sp"
                            android:textColor="#666666"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19.50"
                        android:textSize="11sp"
                        android:textColor="#999999"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="90dp"/>

        </LinearLayout>

    </ScrollView>
    <!-- ========================================= -->
    <!-- BOTTOM NAVIGATION -->
    <!-- ========================================= -->

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_bottom_navigation"
        android:orientation="horizontal"
        android:elevation="10dp"
        android:gravity="center"
        android:weightSum="4"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/uil_calender"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari Ini"
                android:textColor="#909090"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- WAWASAN -->

        <LinearLayout
            android:id="@+id/navInsight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:src="@drawable/material_symbols_menu_book_outline_rounded" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wawasan"
                android:textColor="#909090"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- PESAN AKTIF -->

        <LinearLayout
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/mingcute_message_3_ai_line"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesan"
                android:textColor="#FF6B8A"
                android:textStyle="bold"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- PROFIL -->

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="18dp"
                android:src="@drawable/mdi_face_woman_profile" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textColor="#909090"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>